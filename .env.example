# Path to the JSON config file declaring sources, tiers, thresholds, and the arbiter
PEER_REVIEW_CONFIG=./peer-review.config.json

# Per-source request timeout (ms)
PEER_TIMEOUT_MS=120000

# Hard overall deadline for a peer_review call (ms) — a degraded result is returned on expiry
PEER_REVIEW_DEADLINE_MS=240000

# Max output tokens injected server-side into every peer call
PEER_MAX_OUTPUT_TOKENS=8192

# TTL (seconds) for credentials minted via apiKeyCommand
PEER_CREDENTIAL_TTL_S=3000

# pino log level (logs go to stderr; stdout is reserved for the MCP stdio transport)
LOG_LEVEL=info

# API keys are referenced by env-var NAME from the config file's apiKeyEnv fields, e.g.:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
